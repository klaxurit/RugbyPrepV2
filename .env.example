# ============================================
# RugbyPrep — Variables d'environnement client (Vite)
# Copier vers .env.local et renseigner les valeurs
# ============================================

# Supabase — Projet et clé publique
# Dashboard: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Optionnel: alias pour anon key (compatibilité)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Web Push (VAPID) — clé publique uniquement
# Générer: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=BOA7VUFA-YTeavm4_oiob3J_Uzr_a7diqORkYKG1HNoG3UBLuMWUmJqE_yrfzJUWBqXYc0Pl2S507ky2QZsPUvI

# PostHog Analytics — clé projet (région EU)
# Dashboard: https://app.posthog.com
VITE_POSTHOG_KEY=

# ============================================
# Supabase Edge Functions (configurer via Supabase secrets)
# Ces variables ne vont pas dans .env.local
# Dashboard: Supabase > Project Settings > Edge Functions > Secrets
# ============================================
